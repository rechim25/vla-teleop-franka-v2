{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "robot_observation.schema.json",
  "title": "Robot Observation",
  "type": "object",
  "required": ["timestamp_ns", "robot_state", "executed_action", "status"],
  "properties": {
    "timestamp_ns": {"type": "integer", "minimum": 0},
    "robot_state": {
      "type": "object",
      "required": ["q", "dq", "tcp_position_xyz", "tcp_orientation_xyzw", "gripper_width"],
      "properties": {
        "q": {"type": "array", "items": {"type": "number"}, "minItems": 7, "maxItems": 7},
        "dq": {"type": "array", "items": {"type": "number"}, "minItems": 7, "maxItems": 7},
        "tcp_position_xyz": {
          "type": "array",
          "items": {"type": "number"},
          "minItems": 3,
          "maxItems": 3
        },
        "tcp_orientation_xyzw": {
          "type": "array",
          "items": {"type": "number"},
          "minItems": 4,
          "maxItems": 4
        },
        "gripper_width": {"type": "number"}
      }
    },
    "executed_action": {
      "type": "object",
      "required": ["cartesian_delta_translation", "cartesian_delta_rotation", "gripper_command"],
      "properties": {
        "cartesian_delta_translation": {
          "type": "array",
          "items": {"type": "number"},
          "minItems": 3,
          "maxItems": 3
        },
        "cartesian_delta_rotation": {
          "type": "array",
          "items": {"type": "number"},
          "minItems": 3,
          "maxItems": 3
        },
        "gripper_command": {"type": "number"}
      }
    },
    "status": {
      "type": "object",
      "required": ["control_mode", "teleop_state", "packet_age_ns", "fault_flags"],
      "properties": {
        "control_mode": {"type": "string"},
        "teleop_state": {"type": "string"},
        "packet_age_ns": {"type": "integer", "minimum": 0},
        "fault_flags": {"type": "object"}
      }
    }
  }
}
